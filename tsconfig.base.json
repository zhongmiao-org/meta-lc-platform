{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@zhongmiao/meta-lc-query": [
        "packages/query/src"
      ],
      "@zhongmiao/meta-lc-permission": [
        "packages/permission/src"
      ],
      "@zhongmiao/meta-lc-datasource": [
        "packages/datasource/src"
      ],
      "@zhongmiao/meta-lc-kernel": [
        "packages/kernel/src"
      ],
      "@zhongmiao/meta-lc-migration": [
        "packages/migration/src"
      ],
      "@zhongmiao/meta-lc-audit": [
        "packages/audit/src"
      ],
      "@zhongmiao/meta-lc-contracts": [
        "packages/contracts/src"
      ],
      "@zhongmiao/meta-lc-runtime": [
        "packages/runtime/src"
      ],
      "@zhongmiao/meta-lc-shared": [
        "packages/shared/src"
      ],
      "@zhongmiao/meta-lc-bff": [
        "packages/bff/src"
      ]
    }
  }
}
