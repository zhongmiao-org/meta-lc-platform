{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@zhongmiao/meta-lc-query": [
        "packages/query/src"
      ],
      "@zhongmiao/meta-lc-permission": [
        "packages/permission/src"
      ],
      "@zhongmiao/meta-lc-datasource": [
        "packages/datasource/src"
      ],
      "@zhongmiao/meta-lc-datasource/postgres": [
        "packages/datasource/src/postgres"
      ],
      "@zhongmiao/meta-lc-kernel": [
        "packages/kernel/src"
      ],
      "@zhongmiao/meta-lc-audit": [
        "packages/audit/src"
      ],
      "@zhongmiao/meta-lc-audit/postgres": [
        "packages/audit/src/postgres"
      ],
      "@zhongmiao/meta-lc-runtime": [
        "packages/runtime/src"
      ],
      "@zhongmiao/meta-lc-bff": [
        "packages/bff/src"
      ],
      "@zhongmiao/meta-lc-kernel-adapter-postgres": [
        "packages/kernel-adapter-postgres/src"
      ]
    }
  }
}
