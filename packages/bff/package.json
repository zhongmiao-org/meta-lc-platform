{
  "name": "@zhongmiao/meta-lc-bff",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "pnpm --filter @zhongmiao/meta-lc-bff... build && rm -rf dist-test && tsc -p tsconfig.test.json && node --test \"dist-test/test/*.test.js\"",
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "start": "sh -c 'if [ -f ../../.env ]; then exec node --env-file=../../.env dist/bootstrap/main.js; else exec node dist/bootstrap/main.js; fi'"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.12",
    "@nestjs/core": "^10.4.12",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@zhongmiao/meta-lc-runtime": "workspace:*",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "nx": {
    "tags": ["layer:bff"]
  }
}
