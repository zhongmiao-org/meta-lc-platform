{
  "name": "@zhongmiao/meta-lc-runtime",
  "version": "0.1.1",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "pnpm --filter @zhongmiao/meta-lc-runtime... build && rm -rf dist-test && tsc -p tsconfig.test.json && node --test \"dist-test/test/*.test.js\"",
    "lint": "echo lint:runtime"
  },
  "dependencies": {
    "@zhongmiao/meta-lc-audit": "workspace:*",
    "@zhongmiao/meta-lc-datasource": "workspace:*",
    "@zhongmiao/meta-lc-kernel": "workspace:*",
    "@zhongmiao/meta-lc-permission": "workspace:*",
    "@zhongmiao/meta-lc-query": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "core": [
        "dist/core/index.d.ts"
      ]
    }
  },
  "nx": {
    "tags": [
      "layer:runtime"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "require": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README_zh.md",
    "CHANGELOG.md",
    "CHANGELOG.zh-CN.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
