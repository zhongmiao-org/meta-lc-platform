{
  "name": "@zhongmiao/meta-lc-datasource",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "npm run build && rm -rf dist-test && tsc -p tsconfig.test.json && node --test \"dist-test/test/*.test.js\"",
    "lint": "echo lint:datasource"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "nx": {
    "tags": [
      "layer:datasource"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "require": "./dist/postgres/index.js",
      "default": "./dist/postgres/index.js"
    }
  }
}
