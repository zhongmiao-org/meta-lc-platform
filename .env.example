# BFF runtime
PORT=3000
NODE_ENV=development

# Bootstrap mode: auto | manual
LC_DB_BOOTSTRAP_MODE=auto

# Database config
LC_DB_HOST=your-postgres-host
LC_DB_PORT=5432
LC_DB_USER=your-postgres-user
LC_DB_PASSWORD=your-postgres-password
LC_DB_NAME=your-business-db
LC_DB_META_NAME=your-meta-db
LC_DB_BUSINESS_NAME=your-business-db
LC_DB_AUDIT_NAME=your-audit-db
LC_DB_SSL=false

# Optional database URLs (override the host/port/name settings above if provided)
LC_DB_META_URL=
LC_DB_BUSINESS_URL=
LC_DB_AUDIT_URL=
LC_DB_BOOTSTRAP_URL=

# Redis config
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=

# Safety guard
LC_MIGRATION_ALLOW_DESTRUCTIVE=false
